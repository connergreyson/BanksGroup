# Formspree contact form - https://formspree.io (endpoint must match index.html contact form action)
CONTACT_FORM_ENDPOINT=https://formspree.io/f/mjgpwdjj

# Realtor.com API (RapidAPI) - https://rapidapi.com/s.mahmoud97/api/realtor16
RAPIDAPI_KEY=your_rapidapi_key_here

# --- GitHub Actions (duplicate in the repo, not in git) ---
# Repository: Settings → Secrets and variables → Actions
#   Secrets: RAPIDAPI_KEY (required for daily API refresh in CI)
#            REALTOR_FULFILLMENT_ID (recommended; or rely on advertiser lookup below)
#            REALTOR_ADVERTISER_ID (optional; for auto-lookup if fulfillment id omitted)
#   Variables: REALTOR_AGENT_LOCATION (optional; defaults to salado, tx in workflow)
# The workflow file: .github/workflows/refresh-listings.yml (must be on the default branch)

# FULFILLMENT_ID: The API expects this (numeric), NOT the MongoDB id from the profile URL.
# To find it: run ./fetch-listings.sh --find-fulfillment-id
# Or: agent search by location, find agent with matching id, use their fulfillment_id.
REALTOR_FULFILLMENT_ID=

# Profile URL id (5b1ae745b328d7001710fe3d) - used with AGENT_LOCATION for auto lookup
REALTOR_ADVERTISER_ID=5b1ae745b328d7001710fe3d
REALTOR_AGENT_LOCATION=salado, tx
